# Redis connection
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# IP-based rate limiting
# Maximum requests per second per IP address
RATE_LIMIT_IP_MAX_REQUESTS=10
# How long (in seconds) to block an IP after it exceeds the limit
RATE_LIMIT_IP_BLOCK_DURATION_SECONDS=300

# Token-based rate limiting (default — applies to all tokens without a specific config)
# Token limits override IP limits when the API_KEY header is present
RATE_LIMIT_TOKEN_MAX_REQUESTS=100
RATE_LIMIT_TOKEN_BLOCK_DURATION_SECONDS=300

# Per-token overrides (optional)
# Format: token:maxRequests:blockSeconds,token2:maxRequests:blockSeconds
# Example: TOKEN_RATE_LIMITS=abc123:200:60,xyz789:50:600
TOKEN_RATE_LIMITS=
